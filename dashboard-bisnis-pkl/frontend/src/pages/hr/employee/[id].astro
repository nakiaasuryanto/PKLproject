---
import MainLayout from '../../../layouts/MainLayout.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001/api';

const { id } = Astro.params;
---

<MainLayout title="Detail Karyawan - HR" activeModule="hr">
  <!-- Page Header -->
  <div class="mb-8">
    <a href="/hr" class="inline-flex items-center text-hr-600 hover:text-hr-700 mb-4">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali ke HR
    </a>

    <div id="employeeHeader" class="flex flex-col md:flex-row md:items-center md:justify-between">
      <!-- Content loaded dynamically -->
    </div>
  </div>

  <!-- Stats Cards -->
  <div id="statsCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <!-- Content loaded dynamically -->
  </div>

  <div id="contentGrid" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column: Employee Info -->
    <div class="lg:col-span-1 space-y-6">
      <div id="personalInfo"></div>
      <div id="employmentInfo"></div>
    </div>

    <!-- Right Column: Attendance History -->
    <div class="lg:col-span-2">
      <div id="attendanceHistory"></div>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loadingState" class="flex items-center justify-center py-20">
    <div class="text-center">
      <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-hr-200 border-t-hr-600"></div>
      <p class="mt-4 text-gray-600">Memuat data karyawan...</p>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="editModal" class="fixed inset-0 z-50 hidden" aria-labelledby="edit-modal-title" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onclick="closeEditModal()"></div>
    <div class="fixed inset-0 z-10 overflow-y-auto">
      <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:w-full sm:max-w-lg">
          <div class="bg-hr-500 px-4 py-4 sm:px-6">
            <h3 class="text-lg font-semibold text-white">Edit Karyawan</h3>
          </div>
          <form id="editEmployeeForm" class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-1">Nama</label>
                <input type="text" name="name" id="editName" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" name="email" id="editEmail" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Telepon</label>
                <input type="tel" name="phone" id="editPhone" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Posisi</label>
                <input type="text" name="position" id="editPosition" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Departemen</label>
                <select name="department" id="editDepartment" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500">
                  <option value="Management">Management</option>
                  <option value="IT">IT</option>
                  <option value="Customer Service">Customer Service</option>
                  <option value="Operations">Operations</option>
                  <option value="Finance">Finance</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Gaji</label>
                <input type="number" name="salary" id="editSalary" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select name="status" id="editStatus" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-hr-500 focus:border-hr-500">
                  <option value="ACTIVE">Aktif</option>
                  <option value="INACTIVE">Tidak Aktif</option>
                  <option value="TRAINING">Training</option>
                  <option value="PROBATION">Masa Percobaan</option>
                </select>
              </div>
            </div>
            <div class="flex gap-3 pt-4">
              <button type="submit" class="flex-1 bg-hr-600 text-white py-2 px-4 rounded-lg hover:bg-hr-700 transition-colors font-medium">
                Simpan Perubahan
              </button>
              <button type="button" onclick="closeEditModal()" class="flex-1 bg-gray-300 text-gray-700 py-2 px-4 rounded-lg hover:bg-gray-400 transition-colors font-medium">
                Batal
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script define:vars={{ id, API_BASE }}>
  let currentEmployee = null;

  async function fetchEmployeeData() {
    try {
      const response = await fetch(`${API_BASE}/employees/${id}`, { credentials: 'include' });
      const result = await response.json();

      if (!result.success) {
        window.location.href = '/hr';
        return;
      }

      currentEmployee = result.data;
      renderEmployeeDetail(result.data);
    } catch (error) {
      console.error('Error fetching employee:', error);
      const loadingEl = document.getElementById('loadingState');
      if (loadingEl) {
        loadingEl.innerHTML = `
          <div class="text-center text-red-600">
            <p>Gagal memuat data karyawan</p>
            <a href="/hr" class="text-hr-600 hover:text-hr-700">Kembali ke daftar</a>
          </div>
        `;
      }
    }
  }

  function renderEmployeeDetail(employee) {
    const loadingState = document.getElementById('loadingState');
    if (loadingState) loadingState.style.display = 'none';

    const attendance = employee.attendance || [];

    // Calculate attendance stats
    const presentDays = attendance.filter(a => a.status === 'PRESENT').length;
    const lateDays = attendance.filter(a => a.status === 'LATE').length;
    const absentDays = attendance.filter(a => a.status === 'ABSENT' || a.status === 'SICK' || a.status === 'LEAVE').length;
    const totalHours = attendance.reduce((sum, a) => sum + (a.work_hours || 0), 0);
    const attendanceRate = attendance.length > 0 ? ((presentDays + lateDays) / attendance.length * 100) : 0;

    // Render header
    document.getElementById('employeeHeader').innerHTML = `
      <div>
        <div class="flex items-center space-x-3">
          <div class="w-16 h-16 bg-hr-100 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-hr-600">
              ${employee.name.split(' ').map(n => n[0]).join('').slice(0, 2)}
            </span>
          </div>
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">${employee.name}</h1>
            <p class="text-gray-600">${employee.position} - ${employee.department}</p>
          </div>
        </div>
      </div>
      <div class="mt-4 md:mt-0 flex space-x-3">
        <button onclick="openEditModal()" class="inline-flex items-center justify-center font-medium rounded-lg border-2 border-hr-500 text-hr-600 hover:bg-hr-50 focus:outline-none focus:ring-2 focus:ring-hr-500 px-4 py-2 text-sm">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit
        </button>
      </div>
    `;

    // Render stats
    document.getElementById('statsCards').innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-hr-50 to-hr-100 border-hr-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Tingkat Kehadiran</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">${attendanceRate.toFixed(1)}%</p>
          </div>
          <div class="p-3 rounded-xl bg-hr-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-hr-50 to-hr-100 border-hr-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Hari Hadir</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">${presentDays}</p>
          </div>
          <div class="p-3 rounded-xl bg-green-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-hr-50 to-hr-100 border-hr-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Hari Terlambat</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">${lateDays}</p>
          </div>
          <div class="p-3 rounded-xl bg-yellow-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-hr-50 to-hr-100 border-hr-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Total Jam Kerja</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">${totalHours.toFixed(1)}h</p>
          </div>
          <div class="p-3 rounded-xl bg-hr-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>
    `;

    // Personal Info
    document.getElementById('personalInfo').innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-hr-200">
        <div class="px-6 py-4 border-b border-hr-200">
          <h3 class="text-lg font-semibold text-hr-700">Informasi Pribadi</h3>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Kode Karyawan</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${employee.employee_code}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Email</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${employee.email || '-'}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Telepon</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${employee.phone || '-'}</p>
          </div>
        </div>
      </div>
    `;

    // Employment Info
    document.getElementById('employmentInfo').innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-hr-200">
        <div class="px-6 py-4 border-b border-hr-200">
          <h3 class="text-lg font-semibold text-hr-700">Informasi Pekerjaan</h3>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Posisi</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${employee.position}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Departemen</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${employee.department}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Tanggal Bergabung</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${new Date(employee.hire_date).toLocaleDateString('id-ID')}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Status</p>
            <span class="px-2 py-1 text-xs font-semibold rounded-full ${employee.status === 'ACTIVE' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}">
              ${employee.status}
            </span>
          </div>
        </div>
      </div>
    `;

    // Attendance History
    const attendanceRows = attendance.length > 0
      ? attendance.slice(0, 20).map(a => {
          const statusClass = a.status === 'PRESENT' ? 'bg-green-100 text-green-800'
            : a.status === 'LATE' ? 'bg-yellow-100 text-yellow-800'
            : a.status === 'HOLIDAY' ? 'bg-blue-100 text-blue-800'
            : 'bg-red-100 text-red-800';

          return `
            <tr class="hover:bg-hr-50">
              <td class="px-6 py-4 text-sm text-gray-900">
                ${new Date(a.attendance_date).toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short' })}
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">${a.check_in || '-'}</td>
              <td class="px-6 py-4 text-sm text-gray-600">${a.check_out || '-'}</td>
              <td class="px-6 py-4 text-sm font-semibold text-gray-900">${a.work_hours ? a.work_hours.toFixed(1) + 'h' : '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-semibold rounded-full ${statusClass}">
                  ${a.status}
                </span>
              </td>
            </tr>
          `;
        }).join('')
      : `<tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Belum ada riwayat kehadiran</td></tr>`;

    document.getElementById('attendanceHistory').innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-hr-200">
        <div class="px-6 py-4 border-b border-hr-200">
          <h3 class="text-lg font-semibold text-hr-700">Riwayat Kehadiran</h3>
        </div>
        <div class="p-6 overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tanggal</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Masuk</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Pulang</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Jam Kerja</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${attendanceRows}
            </tbody>
          </table>
        </div>
      </div>
    `;
  }

  // Open edit modal
  function openEditModal() {
    if (!currentEmployee) return;

    document.getElementById('editName').value = currentEmployee.name || '';
    document.getElementById('editEmail').value = currentEmployee.email || '';
    document.getElementById('editPhone').value = currentEmployee.phone || '';
    document.getElementById('editPosition').value = currentEmployee.position || '';
    document.getElementById('editDepartment').value = currentEmployee.department || 'Operations';
    document.getElementById('editSalary').value = currentEmployee.salary || '';
    document.getElementById('editStatus').value = currentEmployee.status || 'ACTIVE';

    document.getElementById('editModal').classList.remove('hidden');
  }
  window.openEditModal = openEditModal;

  // Close edit modal
  function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
  }
  window.closeEditModal = closeEditModal;

  // Handle edit form submission
  document.getElementById('editEmployeeForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(e.target);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      position: formData.get('position'),
      department: formData.get('department'),
      salary: formData.get('salary') ? parseInt(formData.get('salary')) : null,
      status: formData.get('status')
    };

    try {
      const response = await fetch(`${API_BASE}/employees/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (result.success) {
        alert('Karyawan berhasil diupdate!');
        closeEditModal();
        location.reload();
      } else {
        alert('Gagal mengupdate karyawan: ' + (result.error || 'Unknown error'));
      }
    } catch (error) {
      console.error('Error updating employee:', error);
      alert('Terjadi kesalahan saat mengupdate karyawan');
    }
  });

  // Fetch data on page load
  fetchEmployeeData();
</script>
