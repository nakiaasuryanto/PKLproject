---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/ui/Card.astro';
import StatCard from '../components/ui/StatCard.astro';
import Button from '../components/ui/Button.astro';
import ChartWrapper from '../components/charts/ChartWrapper.astro';
import { api } from '../lib/api';

// Fetch sales data from backend API
const salesStatsResponse = await api.get('/transactions/stats?start_date=2025-01-01');
const salesTrendResponse = await api.get('/dashboard/sales-trend?period=daily&limit=30');
const recentTransactionsResponse = await api.get('/transactions?type=SALE&limit=10');

const stats = (salesStatsResponse.success && Array.isArray(salesStatsResponse.data)) ? salesStatsResponse.data : [];
const trend = (salesTrendResponse.success && Array.isArray(salesTrendResponse.data)) ? salesTrendResponse.data : [];
const transactions = (recentTransactionsResponse.success && Array.isArray(recentTransactionsResponse.data)) ? recentTransactionsResponse.data : [];

// Calculate metrics from API data
const saleStats = Array.isArray(stats) ? stats.find((s: any) => s.transaction_type === 'SALE') || { total: 0, count: 0 } : { total: 0, count: 0 };
const totalSales = saleStats.total || 0;
const salesCount = saleStats.count || 0;
const avgPerTransaction = salesCount > 0 ? Math.round(totalSales / salesCount) : 0;

// Format currency
function formatCurrency(amount: number): string {
  if (amount >= 1000000) {
    return `Rp ${(amount / 1000000).toFixed(1)}M`;
  } else if (amount >= 1000) {
    return `Rp ${(amount / 1000).toFixed(0)}K`;
  }
  return `Rp ${amount.toLocaleString('id-ID')}`;
}
---

<MainLayout title="Penjualan - Dashboard Bisnis" activeModule="sales">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Dashboard Penjualan</h1>
      <p class="mt-2 text-gray-600">Monitor performa penjualan dan transaksi</p>
    </div>
    <div class="mt-4 sm:mt-0">
      <Button variant="primary" color="sales" size="lg" href="/sales/invoice/new">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Buat Invoice Baru
      </Button>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-8">
    <StatCard
      title="Total Penjualan"
      value={formatCurrency(totalSales)}
      change={totalSales > 0 ? "Data tersedia" : "Belum ada data"}
      changeType={totalSales > 0 ? "positive" : "neutral"}
      color="sales"
      icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
    />
    <StatCard
      title="Jumlah Transaksi"
      value={salesCount}
      change={salesCount > 0 ? `${salesCount} transaksi` : "Belum ada transaksi"}
      changeType={salesCount > 0 ? "positive" : "neutral"}
      color="sales"
      icon="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
    />
    <StatCard
      title="Rata-rata per Transaksi"
      value={avgPerTransaction > 0 ? formatCurrency(avgPerTransaction) : "Rp 0"}
      change={avgPerTransaction > 0 ? "Rata-rata tersedia" : "Belum ada data"}
      changeType="neutral"
      color="sales"
      icon="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
    />
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Sales Trend Chart -->
    <Card title="Tren Penjualan (30 Hari)" color="sales">
      <ChartWrapper chartId="salesTrendChart" height="300px" />
    </Card>

    <!-- Sales by Payment Method -->
    <Card title="Metode Pembayaran" color="sales">
      <ChartWrapper chartId="paymentMethodChart" height="300px" />
    </Card>
  </div>

  <!-- Recent Transactions Table -->
  <Card title="Transaksi Terbaru" color="sales" className="overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="text-xs uppercase bg-sales-50 text-sales-700">
          <tr>
            <th class="px-6 py-3">Tanggal</th>
            <th class="px-6 py-3">Customer</th>
            <th class="px-6 py-3">Total</th>
            <th class="px-6 py-3">Pembayaran</th>
            <th class="px-6 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {transactions.length > 0 ? transactions.map((tx: any) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                {new Date(tx.transaction_date).toLocaleDateString('id-ID', {
                  day: 'numeric',
                  month: 'short',
                  year: 'numeric'
                })}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                {tx.customer_name || 'Walk-in Customer'}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-sales-600">
                {formatCurrency(tx.total_amount)}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                {tx.payment_method || '-'}
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`px-2 py-1 text-xs font-medium rounded-full ${
                  tx.payment_status === 'COMPLETED' || tx.payment_status === 'PAID'
                    ? 'bg-green-100 text-green-800'
                    : tx.payment_status === 'PENDING'
                    ? 'bg-yellow-100 text-yellow-800'
                    : 'bg-gray-100 text-gray-800'
                }`}>
                  {tx.payment_status || 'N/A'}
                </span>
              </td>
            </tr>
          )) : (
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <p>Belum ada data transaksi</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    {transactions.length > 0 && (
      <div class="mt-6 text-center">
        <a href="/sales/transactions" class="text-sm font-medium text-sales-600 hover:text-sales-700 inline-flex items-center">
          Lihat Semua Transaksi
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    )}
  </Card>
</MainLayout>

<script>
  import { createLineChart, createDoughnutChart } from '../lib/chartUtils';

  // Define global interface for window data
  interface WindowData {
    salesTrendData?: any[];
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Get trend data from server (passed via global)
    const trendData = (window as unknown as WindowData).salesTrendData || [];

    // Sales Trend Chart
    if (trendData.length > 0) {
      const labels = trendData.map((d: any) => {
        const date = new Date(d.period);
        return date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short' });
      });
      const salesData = trendData.map((d: any) => d.sales || 0);

      createLineChart('salesTrendChart', labels, [
        {
          label: 'Penjualan',
          data: salesData,
          borderColor: '#EF4444',
          backgroundColor: 'rgba(239, 68, 68, 0.1)',
          tension: 0.4,
          fill: true
        }
      ]);
    } else {
      // Show empty state when no data available
      createLineChart('salesTrendChart',
        ['Belum Ada Data'],
        [{
          label: 'Penjualan',
          data: [0],
          borderColor: '#E5E7EB',
          backgroundColor: 'rgba(229, 231, 235, 0.1)',
          tension: 0.4,
          fill: true
        }]
      );
    }

    // Payment Method Chart - show empty when no data
    if (trendData.length > 0) {
      // Calculate payment methods from API data
      const paymentMethods: { [key: string]: number } = {};
      trendData.forEach((d: any) => {
        if (d.payment_method) {
          paymentMethods[d.payment_method] = (paymentMethods[d.payment_method] || 0) + 1;
        }
      });

      const labels = Object.keys(paymentMethods);
      const data = Object.values(paymentMethods);

      if (labels.length > 0) {
        createDoughnutChart(
          'paymentMethodChart',
          labels,
          data,
          ['#EF4444', '#F87171', '#FCA5A5', '#FECACA']
        );
      } else {
        createDoughnutChart(
          'paymentMethodChart',
          ['Belum Ada Data'],
          [1],
          ['#E5E7EB']
        );
      }
    } else {
      createDoughnutChart(
        'paymentMethodChart',
        ['Belum Ada Data'],
        [1],
        ['#E5E7EB']
      );
    }
  });
</script>

<style define:vars={{ salesTrendData: JSON.stringify(trend) }}>
</style>
