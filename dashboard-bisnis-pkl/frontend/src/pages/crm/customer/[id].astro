---
import MainLayout from '../../../layouts/MainLayout.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || '${API_BASE}';

// Get customer ID from URL params
const { id } = Astro.params;
---

<MainLayout title={`Customer Detail - CRM`} activeModule="crm">
  <!-- Page Header -->
  <div class="mb-8">
    <a href="/crm" class="inline-flex items-center text-crm-600 hover:text-crm-700 mb-4">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali ke Daftar Customer
    </a>

    <div id="customerHeader" class="flex flex-col md:flex-row md:items-center md:justify-between">
      <!-- Content loaded dynamically -->
    </div>
  </div>

  <!-- Stats Cards -->
  <div id="statsCards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <!-- Content loaded dynamically -->
  </div>

  <div id="contentGrid" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column: Contact Info -->
    <div class="lg:col-span-1 space-y-6">
      <div id="contactInfo"></div>
      <div id="companyInfo"></div>
      <div id="paymentInfo"></div>
    </div>

    <!-- Right Column: Purchase History -->
    <div class="lg:col-span-2">
      <div id="purchaseHistory"></div>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loadingState" class="flex items-center justify-center py-20">
    <div class="text-center">
      <div class="inline-block animate-spin rounded-full h-12 w-12 border-4 border-crm-200 border-t-crm-600"></div>
      <p class="mt-4 text-gray-600">Memuat data customer...</p>
    </div>
  </div>
</MainLayout>

<script define:vars={{ id }}>
  const API_BASE = '${API_BASE}';

  async function fetchCustomerData() {
    try {
      const [customerRes, purchasesRes] = await Promise.all([
        fetch(`${API_BASE}/customers/${id}`, { credentials: 'include' }),
        fetch(`${API_BASE}/customers/${id}/purchases`, { credentials: 'include' })
      ]);

      const customerData = await customerRes.json();
      const purchasesData = await purchasesRes.json();

      if (!customerData.success) {
        window.location.href = '/crm';
        return;
      }

      const customer = customerData.data;
      const purchases = purchasesData.success ? purchasesData.data : [];

      renderCustomerDetail(customer, purchases);
    } catch (error) {
      console.error('Error fetching customer:', error);
      document.getElementById('loadingState')!.innerHTML = `
        <div class="text-center text-red-600">
          <p>Gagal memuat data customer</p>
          <a href="/crm" class="text-crm-600 hover:text-crm-700">Kembali ke daftar</a>
        </div>
      `;
    }
  }

  function renderCustomerDetail(customer: any, purchases: any[]) {
    // Hide loading state
    document.getElementById('loadingState')!.style.display = 'none';

    // Render header
    const header = document.getElementById('customerHeader')!;
    header.innerHTML = `
      <div>
        <div class="flex items-center space-x-3">
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">${customer.name}</h1>
          <span class="px-3 py-1 text-sm font-semibold rounded-full ${customer.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}">
            ${customer.status === 'active' ? 'Aktif' : 'Tidak Aktif'}
          </span>
        </div>
        <p class="mt-2 text-gray-600">
          ${customer.company_name || customer.customer_type} • ${customer.city}
        </p>
      </div>
      <div class="mt-4 md:mt-0 flex space-x-3">
        <a href="/sales/invoice/new?customer_id=${customer.id}" class="inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm bg-sales-500 text-white hover:bg-sales-600 focus:ring-sales-500 shadow-sm hover:shadow">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Buat Pesanan
        </a>
        <a href="/crm" class="inline-flex items-center justify-center font-medium rounded-lg border-2 border-crm-500 text-crm-600 hover:bg-crm-50 focus:outline-none focus:ring-2 focus:ring-crm-500 px-4 py-2 text-sm">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit
        </a>
      </div>
    `;

    // Render stats cards
    const avgOrder = customer.total_purchases > 0
      ? (customer.total_spent / customer.total_purchases / 1000000).toFixed(1)
      : '0.0';

    const lastOrder = customer.last_order_date
      ? new Date(customer.last_order_date).toLocaleDateString('id-ID')
      : 'Belum ada';

    document.getElementById('statsCards')!.innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-crm-50 to-crm-100 border-crm-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Total Pembelanjaan</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">Rp ${((customer.total_spent || 0) / 1000000).toFixed(1)}M</p>
          </div>
          <div class="p-3 rounded-xl bg-crm-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-crm-50 to-crm-100 border-crm-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Total Pesanan</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">${customer.total_purchases || 0}</p>
          </div>
          <div class="p-3 rounded-xl bg-crm-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-crm-50 to-crm-100 border-crm-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Rata-rata Order</p>
            <p class="mt-2 text-2xl font-bold text-gray-900">Rp ${avgOrder}M</p>
          </div>
          <div class="p-3 rounded-xl bg-crm-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border bg-gradient-to-br from-crm-50 to-crm-100 border-crm-200 p-6">
        <div class="flex items-center justify-between">
          <div class="flex-1">
            <p class="text-sm font-medium text-gray-600 uppercase tracking-wide">Terakhir Order</p>
            <p class="mt-2 text-sm font-bold text-gray-900">${lastOrder}</p>
          </div>
          <div class="p-3 rounded-xl bg-crm-500 text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        </div>
      </div>
    `;

    // Contact Info
    document.getElementById('contactInfo')!.innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-crm-200">
        <div class="px-6 py-4 border-b border-crm-200">
          <h3 class="text-lg font-semibold text-crm-700">Informasi Kontak</h3>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Email</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${customer.email || '-'}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Telepon</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${customer.phone}</p>
            <a href="https://wa.me/${customer.whatsapp || customer.phone}" class="text-xs text-crm-600 hover:text-crm-700">
              Chat WhatsApp
            </a>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Kota</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${customer.city}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Alamat</p>
            <p class="text-sm text-gray-600 mt-1">${customer.address || '-'}</p>
          </div>
        </div>
      </div>
    `;

    // Company Info (if applicable)
    const companyInfoDiv = document.getElementById('companyInfo')!;
    if (customer.customer_type === 'COMPANY') {
      companyInfoDiv.innerHTML = `
        <div class="bg-white rounded-xl shadow-sm border border-crm-200">
          <div class="px-6 py-4 border-b border-crm-200">
            <h3 class="text-lg font-semibold text-crm-700">Informasi Perusahaan</h3>
          </div>
          <div class="p-6 space-y-4">
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wider">Nama Perusahaan</p>
              <p class="text-sm font-medium text-gray-900 mt-1">${customer.company_name || '-'}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wider">NPWP</p>
              <p class="text-sm text-gray-600 mt-1">${customer.npwp || '-'}</p>
            </div>
            <div>
              <p class="text-xs text-gray-500 uppercase tracking-wider">Alamat Penagihan</p>
              <p class="text-sm text-gray-600 mt-1">${customer.tax_address || '-'}</p>
            </div>
          </div>
        </div>
      `;
    } else {
      companyInfoDiv.innerHTML = '';
    }

    // Payment Info
    document.getElementById('paymentInfo')!.innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-crm-200">
        <div class="px-6 py-4 border-b border-crm-200">
          <h3 class="text-lg font-semibold text-crm-700">Informasi Pembayaran</h3>
        </div>
        <div class="p-6 space-y-4">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Limit Kredit</p>
            <p class="text-sm font-medium text-gray-900 mt-1">
              ${customer.credit_limit ? `Rp ${customer.credit_limit.toLocaleString('id-ID')}` : 'Tidak ada limit'}
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Termin Pembayaran</p>
            <p class="text-sm font-medium text-gray-900 mt-1">${customer.payment_terms || 'NET14'}</p>
          </div>
          ${customer.notes ? `
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wider">Catatan</p>
            <p class="text-sm text-gray-600 mt-1">${customer.notes}</p>
          </div>
          ` : ''}
        </div>
      </div>
    `;

    // Purchase History
    const purchaseRows = purchases.length > 0
      ? purchases.map((p: any) => {
          const statusClass = p.status === 'PAID'
            ? 'bg-green-100 text-green-800'
            : p.status === 'PENDING'
            ? 'bg-yellow-100 text-yellow-800'
            : 'bg-red-100 text-red-800';
          const statusText = p.status === 'PAID' ? 'Lunas' : p.status === 'PENDING' ? 'Pending' : 'Batal';

          return `
            <tr class="hover:bg-crm-50">
              <td class="px-6 py-4 text-sm font-medium text-gray-900">${p.invoice_number}</td>
              <td class="px-6 py-4 text-sm text-gray-600">
                ${new Date(p.invoice_date).toLocaleDateString('id-ID')}
              </td>
              <td class="px-6 py-4 text-sm font-semibold text-gray-900">
                Rp ${(p.total_amount / 1000000).toFixed(1)}M
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-semibold rounded-full ${statusClass}">
                  ${statusText}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm">
                <a href="/sales/invoice/${p.id}" class="text-crm-600 hover:text-crm-700 font-medium">
                  Detail
                </a>
              </td>
            </tr>
          `;
        }).join('')
      : `<tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Belum ada riwayat pembelian</td></tr>`;

    document.getElementById('purchaseHistory')!.innerHTML = `
      <div class="bg-white rounded-xl shadow-sm border border-crm-200">
        <div class="px-6 py-4 border-b border-crm-200">
          <h3 class="text-lg font-semibold text-crm-700">Riwayat Pembelian</h3>
        </div>
        <div class="p-6 overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">No. Invoice</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tanggal</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Aksi</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              ${purchaseRows}
            </tbody>
          </table>
          ${purchases.length > 0 ? `
          <div class="mt-6 text-center">
            <a href="/sales?customer_id=${customer.id}" class="text-sm font-medium text-crm-600 hover:text-crm-700">
              Lihat Semua Transaksi &rarr;
            </a>
          </div>
          ` : ''}
        </div>
      </div>
    `;
  }

  // Fetch data on page load
  fetchCustomerData();
</script>
