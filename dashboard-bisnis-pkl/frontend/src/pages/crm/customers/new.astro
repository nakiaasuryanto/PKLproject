---
import MainLayout from '../../../layouts/MainLayout.astro';
import Button from '../../../components/ui/Button.astro';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001/api';
---

<MainLayout title="Tambah Customer - CRM" activeModule="crm">
  <!-- Page Header -->
  <div class="mb-8">
    <a href="/crm" class="inline-flex items-center text-crm-600 hover:text-crm-700 mb-4">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Kembali ke CRM
    </a>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Tambah Customer Baru</h1>
    <p class="mt-2 text-gray-600">Lengkapi formulir di bawah untuk menambahkan customer baru</p>
  </div>

  <!-- Form Card -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <form id="customerForm" class="p-6 sm:p-8">
      <!-- Customer Type Section -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
          Tipe Customer
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <label class="relative cursor-pointer">
            <input type="radio" name="customer_type" value="INDIVIDUAL" checked class="peer sr-only">
            <div class="p-4 border-2 border-gray-200 rounded-lg peer-checked:border-crm-500 peer-checked:bg-crm-50 transition-all">
              <div class="text-center">
                <svg class="w-8 h-8 mx-auto mb-2 text-crm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <p class="font-semibold text-gray-900">Individual</p>
                <p class="text-sm text-gray-600">Customer perorangan</p>
              </div>
            </div>
          </label>

          <label class="relative cursor-pointer">
            <input type="radio" name="customer_type" value="COMPANY" class="peer sr-only">
            <div class="p-4 border-2 border-gray-200 rounded-lg peer-checked:border-crm-500 peer-checked:bg-crm-50 transition-all">
              <div class="text-center">
                <svg class="w-8 h-8 mx-auto mb-2 text-crm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                <p class="font-semibold text-gray-900">Perusahaan</p>
                <p class="text-sm text-gray-600">Customer korporat</p>
              </div>
            </div>
          </label>

          <label class="relative cursor-pointer">
            <input type="radio" name="customer_type" value="RESELLER" class="peer sr-only">
            <div class="p-4 border-2 border-gray-200 rounded-lg peer-checked:border-crm-500 peer-checked:bg-crm-50 transition-all">
              <div class="text-center">
                <svg class="w-8 h-8 mx-auto mb-2 text-crm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <p class="font-semibold text-gray-900">Reseller</p>
                <p class="text-sm text-gray-600">Mitra reseller</p>
              </div>
            </div>
          </label>
        </div>
      </div>

      <!-- Company Information (only for COMPANY type) -->
      <div id="companyInfoSection" class="mb-8 hidden">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
          🏢 Informasi Perusahaan
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="md:col-span-2">
            <label for="company_name" class="block text-sm font-medium text-gray-700 mb-2">
              Nama Perusahaan <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="company_name"
              name="company_name"
              placeholder="PT. Contoh Indonesia"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>

          <div>
            <label for="npwp" class="block text-sm font-medium text-gray-700 mb-2">
              NPWP
            </label>
            <input
              type="text"
              id="npwp"
              name="npwp"
              placeholder="XX.XXX.XXX.X-XXX.XXX"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>

          <div>
            <label for="tax_address" class="block text-sm font-medium text-gray-700 mb-2">
              Alamat Penagihan
            </label>
            <input
              type="text"
              id="tax_address"
              name="tax_address"
              placeholder="Alamat untuk kirim invoice"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>
        </div>
      </div>

      <!-- Personal/Contact Information -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
          👤 Informasi Kontak
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="customer_code" class="block text-sm font-medium text-gray-700 mb-2">
              Kode Customer <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="customer_code"
              name="customer_code"
              required
              placeholder="CUST001"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
            <p class="mt-1 text-xs text-gray-500">Kode unik untuk identifikasi customer</p>
          </div>

          <div class="md:col-span-2">
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
              Nama Lengkap / PIC <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Nama lengkap customer atau nama PIC"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
              Email <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="customer@email.com"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
            <p class="mt-1 text-xs text-gray-500">Email akan muncul di detail CRM dan riwayat pembelian</p>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
              No. Telepon <span class="text-red-500">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              placeholder="08xxxxxxxxxx"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
            <p class="mt-1 text-xs text-gray-500">Nomor ini akan muncul di modul Sales</p>
          </div>

          <div>
            <label for="whatsapp" class="block text-sm font-medium text-gray-700 mb-2">
              WhatsApp
            </label>
            <input
              type="tel"
              id="whatsapp"
              name="whatsapp"
              placeholder="08xxxxxxxxxx"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>

          <div>
            <label for="city" class="block text-sm font-medium text-gray-700 mb-2">
              Kota <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="city"
              name="city"
              required
              placeholder="Jakarta"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
          </div>

          <div class="md:col-span-2">
            <label for="address" class="block text-sm font-medium text-gray-700 mb-2">
              Alamat Lengkap
            </label>
            <textarea
              id="address"
              name="address"
              rows="3"
              placeholder="Alamat lengkap customer"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Additional Information -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 pb-2 border-b border-gray-200">
          📝 Informasi Tambahan
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="credit_limit" class="block text-sm font-medium text-gray-700 mb-2">
              Limit Kredit
            </label>
            <input
              type="number"
              id="credit_limit"
              name="credit_limit"
              min="0"
              step="100000"
              placeholder="0"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            />
            <p class="mt-1 text-xs text-gray-500">Limit kredit dalam Rupiah (kosongkan = tidak ada limit)</p>
          </div>

          <div>
            <label for="payment_terms" class="block text-sm font-medium text-gray-700 mb-2">
              Termin Pembayaran
            </label>
            <select
              id="payment_terms"
              name="payment_terms"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            >
              <option value="COD">COD (Cash on Delivery)</option>
              <option value="NET14" selected>Net 14 Hari</option>
              <option value="NET30">Net 30 Hari</option>
              <option value="NET45">Net 45 Hari</option>
              <option value="NET60">Net 60 Hari</option>
            </select>
          </div>

          <div class="md:col-span-2">
            <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
              Catatan
            </label>
            <textarea
              id="notes"
              name="notes"
              rows="2"
              placeholder="Catatan tambahan tentang customer"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-crm-500 focus:border-crm-500"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Form Actions -->
      <div class="flex flex-col sm:flex-row justify-end gap-3 pt-6 border-t border-gray-200">
        <a href="/crm">
          <Button variant="outline" color="crm" size="md" tag="span">
            Batal
          </Button>
        </a>
        <button
          type="submit"
          class="inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 px-6 py-2 text-sm bg-crm-500 text-white hover:bg-crm-600 focus:ring-crm-500 shadow-sm hover:shadow"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Simpan Customer
        </button>
      </div>
    </form>
  </div>
</MainLayout>

<script>
  // Show/hide company info section based on customer type
  const customerTypeInputs = document.querySelectorAll('input[name="customer_type"]');
  const companyInfoSection = document.getElementById('companyInfoSection');
  const companyNameInput = document.getElementById('company_name');

  customerTypeInputs.forEach(input => {
    input?.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.value === 'COMPANY') {
        companyInfoSection?.classList.remove('hidden');
        companyNameInput?.setAttribute('required', 'required');
      } else {
        companyInfoSection?.classList.add('hidden');
        companyNameInput?.removeAttribute('required');
      }
    });
  });

  // Form submission
  const customerForm = document.getElementById('customerForm') as HTMLFormElement;

  customerForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(customerForm);
    const customerType = formData.get('customer_type');

    const data: Record<string, any> = {
      customer_type: customerType,
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      whatsapp: formData.get('whatsapp') || formData.get('phone'),
      city: formData.get('city'),
      address: formData.get('address'),
      credit_limit: formData.get('credit_limit') ? parseInt(formData.get('credit_limit') as string) : null,
      payment_terms: formData.get('payment_terms'),
      notes: formData.get('notes'),
      status: 'active'
    };

    // Add company-specific fields if COMPANY type
    if (customerType === 'COMPANY') {
      data.company_name = formData.get('company_name');
      data.npwp = formData.get('npwp');
      data.tax_address = formData.get('tax_address');
    }

    try {
      const response = await fetch('https://pklproject-production.up.railway.app/api/customers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (result.success) {
        alert('✅ Customer berhasil ditambahkan!');
        window.location.href = '/crm';
      } else {
        alert('❌ ' + (result.error || 'Gagal menambahkan customer'));
      }
    } catch (error) {
      console.error('Error creating customer:', error);
      alert('❌ Terjadi kesalahan saat menambahkan customer');
    }
  });
</script>

<style>
  input:invalid, select:invalid, textarea:invalid {
    border-color: #EF4444;
  }

  input:valid, select:valid, textarea:valid {
    border-color: #10B981;
  }
</style>
