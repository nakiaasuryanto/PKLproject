---
import MainLayout from '../layouts/MainLayout.astro';
import Card from '../components/ui/Card.astro';
import StatCard from '../components/ui/StatCard.astro';
import Button from '../components/ui/Button.astro';
import { api } from '../lib/api';

// Fetch HR data
const employeesData = await api.get('/employees?status=ACTIVE');
const attendanceSummary = await api.get('/employees/attendance/summary');

const employees = (employeesData?.success && Array.isArray(employeesData?.data)) ? employeesData.data : [];
const summary = (attendanceSummary?.success && Array.isArray(attendanceSummary?.data)) ? attendanceSummary.data : [];

// Calculate stats
const totalEmployees = employees.length;
const departmentCounts = employees.reduce((acc: Record<string, number>, e: any) => {
  acc[e.department] = (acc[e.department] || 0) + 1;
  return acc;
}, {});

// Calculate attendance rate
const avgAttendance = summary.length > 0
  ? summary.reduce((sum: number, s: any) => sum + ((s.present_days / s.total_days) * 100), 0) / summary.length
  : 0;

// Get present today count
const presentToday = summary.length > 0 ? summary.filter((s: any) => s.present_days > 0).length : 0;

const currentMonth = new Date().toLocaleString('id-ID', { month: 'long', year: 'numeric' });
---

<MainLayout title="HR - Dashboard Bisnis" activeModule="hr">
  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Human Resources</h1>
      <p class="mt-2 text-gray-600">Manajemen karyawan dan kehadiran</p>
    </div>
    <div class="mt-4 sm:mt-0 flex space-x-3">
      <button
        id="attendanceBtn"
        class="inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 px-4 py-2 text-sm border-2 border-hr-500 text-hr-600 hover:bg-hr-50 focus:ring-hr-500"
      >
        ✅ Absen Hari Ini
      </button>
      <a href="/hr/new-employee">
        <Button variant="primary" color="hr" size="md" tag="span">
          ➕ Tambah Karyawan
        </Button>
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mb-8">
    <StatCard
      title="Total Karyawan"
      value={totalEmployees}
      change="Karyawan aktif"
      changeType="neutral"
      color="hr"
    />
    <StatCard
      title="Tingkat Kehadiran"
      value={`${avgAttendance.toFixed(1)}%`}
      change="Bulan ini"
      changeType={avgAttendance >= 90 ? "positive" : avgAttendance >= 75 ? "neutral" : "negative"}
      color="hr"
    />
    <StatCard
      title="Hadir Hari Ini"
      value={presentToday}
      change={`dari ${totalEmployees} karyawan`}
      changeType="neutral"
      color="hr"
    />
    <StatCard
      title="Departemen"
      value={Object.keys(departmentCounts).length}
      change="Divisi aktif"
      changeType="neutral"
      color="hr"
    />
  </div>

  <!-- Department Breakdown -->
  <Card title="📊 Karyawan per Departemen" color="hr" className="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {Object.entries(departmentCounts).map(([dept, count]) => (
        <div class="text-center p-4 bg-hr-50 rounded-lg">
          <p class="text-3xl font-bold text-hr-600">{count}</p>
          <p class="text-sm text-gray-600 mt-1">{dept}</p>
        </div>
      ))}
    </div>
  </Card>

  <!-- Attendance Summary -->
  <Card title={`📅 Rekap Kehadiran - ${currentMonth}`} color="hr" className="mb-8">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nama</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Departemen</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Total</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Hadir</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Absen</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Terlambat</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Jam</th>
            <th class="px-4 sm:px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Kehadiran</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          {summary.length > 0 ? summary.map((emp: any) => {
            const attendanceRate = emp.total_days > 0 ? (emp.present_days / emp.total_days) * 100 : 0;

            return (
              <tr class="hover:bg-hr-50">
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="w-10 h-10 bg-hr-100 rounded-full flex items-center justify-center flex-shrink-0">
                      <span class="text-sm font-semibold text-hr-600">
                        {emp.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
                      </span>
                    </div>
                    <div class="ml-3 min-w-0">
                      <p class="text-sm font-medium text-gray-900 truncate">{emp.name}</p>
                    </div>
                  </div>
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                  {emp.department}
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center text-sm text-gray-900">
                  {emp.total_days}
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center">
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                    {emp.present_days}
                  </span>
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center">
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-red-100 text-red-800">
                    {emp.absent_days || 0}
                  </span>
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center">
                  <span class="px-2 py-1 text-xs font-semibold rounded-full bg-yellow-100 text-yellow-800">
                    {emp.late_days || 0}
                  </span>
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center text-sm font-semibold text-gray-900">
                  {emp.total_hours?.toFixed(1) || 0}h
                </td>
                <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-center">
                  <div class="flex items-center justify-center space-x-2">
                    <div class="w-20 sm:w-24 bg-gray-200 rounded-full h-2 flex-shrink-0">
                      <div
                        class={`h-2 rounded-full ${
                          attendanceRate >= 90 ? 'bg-green-500' :
                          attendanceRate >= 75 ? 'bg-yellow-500' : 'bg-red-500'
                        }`}
                        style={`width: ${attendanceRate}%`}
                      ></div>
                    </div>
                    <span class="text-sm font-semibold text-gray-700">
                      {attendanceRate.toFixed(0)}%
                    </span>
                  </div>
                </td>
              </tr>
            );
          }) : (
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <p>Belum ada data kehadiran</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </Card>

  <!-- Employee Directory -->
  <Card title="👥 Direktori Karyawan" color="hr">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Kode</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nama</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden sm:table-cell">Posisi</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden md:table-cell">Departemen</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden lg:table-cell">Kontak</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase hidden lg:table-cell">Bergabung</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-4 sm:px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Aksi</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          {employees.length > 0 ? employees.map((emp: any) => (
            <tr class="hover:bg-hr-50">
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                {emp.employee_code}
              </td>
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="w-10 h-10 bg-hr-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-semibold text-hr-600">
                      {emp.name.split(' ').map((n: string) => n[0]).join('').slice(0, 2)}
                    </span>
                  </div>
                  <div class="ml-3 min-w-0">
                    <p class="text-sm font-medium text-gray-900 truncate">{emp.name}</p>
                  </div>
                </div>
              </td>
              <td class="px-4 sm:px-6 py-4 text-sm text-gray-900 hidden sm:table-cell">{emp.position}</td>
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-sm hidden md:table-cell">
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-hr-100 text-hr-800">
                  {emp.department}
                </span>
              </td>
              <td class="px-4 sm:px-6 py-4 text-sm text-gray-600 hidden lg:table-cell">
                <div>
                  <p>{emp.phone}</p>
                  <p class="text-xs text-gray-500">{emp.email}</p>
                </div>
              </td>
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600 hidden lg:table-cell">
                {new Date(emp.hire_date).toLocaleDateString('id-ID')}
              </td>
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap">
                <span class="px-2 py-1 text-xs font-semibold rounded-full bg-green-100 text-green-800">
                  {emp.status}
                </span>
              </td>
              <td class="px-4 sm:px-6 py-4 whitespace-nowrap text-sm">
                <a href={`/hr/employee/${emp.id}`} class="text-hr-600 hover:text-hr-700 font-medium">
                  Detail
                </a>
              </td>
            </tr>
          )) : (
            <tr>
              <td colspan="8" class="px-6 py-8 text-center text-gray-500">
                <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
                <p>Belum ada data karyawan</p>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </Card>

  <!-- Attendance Modal -->
  <div id="attendanceModal" class="fixed inset-0 z-50 hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" id="modalBackdrop"></div>

    <!-- Modal Panel -->
    <div class="fixed inset-0 z-10 overflow-y-auto">
      <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0">
        <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md">
          <!-- Modal Header -->
          <div class="bg-hr-500 px-4 py-4 sm:px-6">
            <h3 class="text-lg font-semibold leading-6 text-white" id="modal-title">
              📅 Absensi Kehadiran
            </h3>
            <p class="mt-1 text-sm text-hr-100">
              {new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          </div>

          <!-- Modal Body -->
          <div class="px-4 py-5 sm:p-6">
            <div class="space-y-4">
              <!-- Current Time -->
              <div class="text-center py-4">
                <p class="text-sm text-gray-500 mb-1">Waktu Sekarang</p>
                <p id="currentTime" class="text-4xl font-bold text-gray-900"></p>
              </div>

              <!-- Attendance Status -->
              <div id="attendanceStatus" class="hidden text-center py-3 px-4 rounded-lg">
                <p class="text-sm font-medium" id="statusText"></p>
              </div>

              <!-- Action Buttons -->
              <div class="grid grid-cols-2 gap-3">
                <button
                  id="checkInBtn"
                  class="flex flex-col items-center justify-center p-4 border-2 border-green-500 rounded-lg hover:bg-green-50 transition-colors"
                >
                  <svg class="w-8 h-8 text-green-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                  </svg>
                  <span class="text-sm font-semibold text-green-700">Check In</span>
                  <span class="text-xs text-gray-500 mt-1">Masuk</span>
                </button>

                <button
                  id="checkOutBtn"
                  class="flex flex-col items-center justify-center p-4 border-2 border-red-500 rounded-lg hover:bg-red-50 transition-colors"
                >
                  <svg class="w-8 h-8 text-red-600 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                  <span class="text-sm font-semibold text-red-700">Check Out</span>
                  <span class="text-xs text-gray-500 mt-1">Pulang</span>
                </button>
              </div>
            </div>
          </div>

          <!-- Modal Footer -->
          <div class="bg-gray-50 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
            <button
              id="closeModalBtn"
              type="button"
              class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 sm:mt-0 sm:w-auto"
            >
              Tutup
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  // Modal elements
  const attendanceBtn = document.getElementById('attendanceBtn');
  const attendanceModal = document.getElementById('attendanceModal');
  const modalBackdrop = document.getElementById('modalBackdrop');
  const closeModalBtn = document.getElementById('closeModalBtn');
  const checkInBtn = document.getElementById('checkInBtn');
  const checkOutBtn = document.getElementById('checkOutBtn');
  const currentTimeEl = document.getElementById('currentTime');
  const attendanceStatus = document.getElementById('attendanceStatus');
  const statusText = document.getElementById('statusText');

  // Open modal
  attendanceBtn?.addEventListener('click', () => {
    attendanceModal?.classList.remove('hidden');
    updateClock();
    checkTodayAttendance();
  });

  // Close modal
  const closeModal = () => {
    attendanceModal?.classList.add('hidden');
  };

  closeModalBtn?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Update clock
  function updateClock() {
    const now = new Date();
    const timeString = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    if (currentTimeEl) {
      currentTimeEl.textContent = timeString;
    }
  }

  // Update clock every second
  setInterval(updateClock, 1000);

  // Check today's attendance
  async function checkTodayAttendance() {
    try {
      const response = await fetch('https://pklproject-production.up.railway.app/api/employees/attendance/today', {
        credentials: 'include'
      });
      const data = await response.json();

      if (data.success && data.data) {
        const attendance = data.data;
        if (attendanceStatus && statusText) {
          attendanceStatus.classList.remove('hidden');
          if (attendance.check_in_time && !attendance.check_out_time) {
            attendanceStatus.className = 'text-center py-3 px-4 rounded-lg bg-green-50';
            statusText.className = 'text-sm font-medium text-green-700';
            statusText.innerHTML = `✅ Sudah Check-In: ${attendance.check_in_time}`;
            checkInBtn?.classList.add('opacity-50', 'cursor-not-allowed');
            checkInBtn?.classList.add('disabled');
          } else if (attendance.check_out_time) {
            attendanceStatus.className = 'text-center py-3 px-4 rounded-lg bg-blue-50';
            statusText.className = 'text-sm font-medium text-blue-700';
            statusText.innerHTML = `👋 Sudah Check-Out: ${attendance.check_out_time}`;
            checkInBtn?.classList.add('opacity-50', 'cursor-not-allowed');
            checkOutBtn?.classList.add('opacity-50', 'cursor-not-allowed');
          } else {
            attendanceStatus.classList.add('hidden');
          }
        }
      }
    } catch (error) {
      console.error('Error checking attendance:', error);
    }
  }

  // Check In
  checkInBtn?.addEventListener('click', async () => {
    try {
      const now = new Date();
      const response = await fetch('https://pklproject-production.up.railway.app/api/employees/attendance/check-in', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          check_in_time: now.toTimeString().slice(0, 5),
          date: now.toISOString().split('T')[0]
        })
      });

      const data = await response.json();
      if (data.success) {
        alert('✅ Check-In berhasil!');
        closeModal();
        location.reload();
      } else {
        alert('❌ ' + (data.error || 'Gagal check-in'));
      }
    } catch (error) {
      alert('❌ Terjadi kesalahan saat check-in');
      console.error(error);
    }
  });

  // Check Out
  checkOutBtn?.addEventListener('click', async () => {
    try {
      const now = new Date();
      const response = await fetch('https://pklproject-production.up.railway.app/api/employees/attendance/check-out', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          check_out_time: now.toTimeString().slice(0, 5),
          date: now.toISOString().split('T')[0]
        })
      });

      const data = await response.json();
      if (data.success) {
        alert('✅ Check-Out berhasil! Hati-hati di jalan!');
        closeModal();
        location.reload();
      } else {
        alert('❌ ' + (data.error || 'Gagal check-out'));
      }
    } catch (error) {
      alert('❌ Terjadi kesalahan saat check-out');
      console.error(error);
    }
  });
</script>
