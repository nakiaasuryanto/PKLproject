---
import MainLayout from '../../layouts/MainLayout.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';
import { api } from '../../lib/api';

// Fetch data for form options
const productsResponse = await api.get('/inventory/products');
const locationsResponse = await api.get('/inventory/locations');
const colorsResponse = await api.get('/inventory/colors');
const sizesResponse = await api.get('/inventory/sizes');

const products = productsResponse.success ? (productsResponse.data || []) : [];
const locations = locationsResponse.success ? (locationsResponse.data || []) : [];
const colors = colorsResponse.success ? (colorsResponse.data || []) : [];
const sizes = sizesResponse.success ? (sizesResponse.data || []) : [];
---

<MainLayout title="Input Stok - Dashboard Bisnis" activeModule="inventory">
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex items-center space-x-2 text-sm text-gray-600 mb-2">
      <a href="/inventory" class="hover:text-inventory-600">Persediaan</a>
      <span>/</span>
      <span class="text-gray-900 font-medium">Input Stok</span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Input Stok Barang</h1>
    <p class="mt-2 text-gray-600">Tambahkan stok barang ke gudang</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Input Form -->
    <div class="lg:col-span-2">
      <Card title="Form Input Stok" color="inventory">
        <form id="stockInputForm" class="space-y-6">
          <!-- Product Selection -->
          <div>
            <label for="productSelect" class="block text-sm font-medium text-gray-700 mb-2">
              Produk <span class="text-red-500">*</span>
            </label>
            <select
              id="productSelect"
              name="product_id"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
            >
              <option value="">Pilih Produk</option>
              {products.map((product: any) => (
                <option value={product.product_id}>{product.product_name}</option>
              ))}
            </select>
          </div>

          <!-- Color & Size -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="colorSelect" class="block text-sm font-medium text-gray-700 mb-2">
                Warna <span class="text-red-500">*</span>
              </label>
              <select
                id="colorSelect"
                name="color_id"
                required
                disabled
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500 disabled:bg-gray-100 disabled:cursor-not-allowed"
              >
                <option value="">Pilih Produk Terlebih Dahulu</option>
              </select>
            </div>

            <div>
              <label for="sizeSelect" class="block text-sm font-medium text-gray-700 mb-2">
                Ukuran <span class="text-red-500">*</span>
              </label>
              <select
                id="sizeSelect"
                name="size_id"
                required
                disabled
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500 disabled:bg-gray-100 disabled:cursor-not-allowed"
              >
                <option value="">Pilih Warna Terlebih Dahulu</option>
              </select>
            </div>
          </div>

          <!-- Variant Info Display -->
          <div id="variantInfo" class="hidden bg-inventory-50 border border-inventory-200 rounded-lg p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-inventory-800">Varian Terpilih</p>
                <p id="variantDetails" class="text-sm text-inventory-600 mt-1">-</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-inventory-800">Stok Saat Ini</p>
                <p id="currentStock" class="text-2xl font-bold text-inventory-600">0</p>
              </div>
            </div>
          </div>

          <!-- Location & Quantity -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="locationSelect" class="block text-sm font-medium text-gray-700 mb-2">
                Lokasi <span class="text-red-500">*</span>
              </label>
              <select
                id="locationSelect"
                name="location_id"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
              >
                <option value="">Pilih Lokasi</option>
                {locations.map((location: any) => (
                  <option value={location.id}>{location.name}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="quantityInput" class="block text-sm font-medium text-gray-700 mb-2">
                Jumlah <span class="text-red-500">*</span>
              </label>
              <input
                type="number"
                id="quantityInput"
                name="quantity"
                min="1"
                required
                placeholder="Masukkan jumlah"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
              >
            </div>
          </div>

          <!-- Unit Cost (Optional) -->
          <div>
            <label for="unitCostInput" class="block text-sm font-medium text-gray-700 mb-2">
              Harga Satuan (Opsional)
            </label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">Rp</span>
              <input
                type="number"
                id="unitCostInput"
                name="unit_cost"
                min="0"
                step="0.01"
                placeholder="0"
                class="w-full pl-12 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
              >
            </div>
          </div>

          <!-- Reason -->
          <div>
            <label for="reasonSelect" class="block text-sm font-medium text-gray-700 mb-2">
              Alasan <span class="text-red-500">*</span>
            </label>
            <select
              id="reasonSelect"
              name="reason_code"
              required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
            >
              <option value="">Pilih Alasan</option>
              <option value="PURCHASE">Pembelian Baru</option>
              <option value="RETURN">Retur Penjualan</option>
              <option value="TRANSFER">Transfer Antar Lokasi</option>
              <option value="ADJUSTMENT_IN">Penyesuaian Stok (Tambah)</option>
              <option value="PRODUCTION">Produksi Sendiri</option>
              <option value="OTHER">Lainnya</option>
            </select>
          </div>

          <!-- Notes -->
          <div>
            <label for="notesInput" class="block text-sm font-medium text-gray-700 mb-2">
              Catatan
            </label>
            <textarea
              id="notesInput"
              name="notes"
              rows="3"
              placeholder="Tambahkan catatan jika diperlukan..."
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-inventory-500 focus:border-inventory-500"
            ></textarea>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-gray-200">
            <Button
              type="submit"
              variant="primary"
              color="inventory"
              size="md"
              class="flex-1"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              Simpan Stok
            </Button>
            <Button
              type="reset"
              variant="outline"
              color="gray"
              size="md"
              class="sm:flex-none"
            >
              Reset Form
            </Button>
          </div>
        </form>
      </Card>
    </div>

    <!-- Sidebar Info -->
    <div class="space-y-6">
      <!-- Quick Guide -->
      <Card title="Panduan Cepat" color="inventory">
        <div class="space-y-4">
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 w-6 h-6 bg-inventory-100 text-inventory-600 rounded-full flex items-center justify-center text-sm font-bold">1</div>
            <p class="text-sm text-gray-600">Pilih produk yang ingin ditambah stoknya</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 w-6 h-6 bg-inventory-100 text-inventory-600 rounded-full flex items-center justify-center text-sm font-bold">2</div>
            <p class="text-sm text-gray-600">Pilih warna dan ukuran varian</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 w-6 h-6 bg-inventory-100 text-inventory-600 rounded-full flex items-center justify-center text-sm font-bold">3</div>
            <p class="text-sm text-gray-600">Tentukan lokasi penyimpanan</p>
          </div>
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0 w-6 h-6 bg-inventory-100 text-inventory-600 rounded-full flex items-center justify-center text-sm font-bold">4</div>
            <p class="text-sm text-gray-600">Masukkan jumlah dan alasan penambahan stok</p>
          </div>
        </div>
      </Card>

      <!-- Recent Activity -->
      <Card title="Aktivitas Terbaru" color="inventory">
        <div id="recentActivity" class="space-y-3">
          <p class="text-sm text-gray-500 text-center py-4">Memuat aktivitas...</p>
        </div>
      </Card>

      <!-- Quick Actions -->
      <Card title="Aksi Cepat" color="inventory">
        <div class="space-y-2">
          <a href="/inventory" class="block w-full text-center px-4 py-2 bg-inventory-50 text-inventory-700 rounded-lg hover:bg-inventory-100 transition-colors text-sm font-medium">
            ← Kembali ke Persediaan
          </a>
          <a href="/inventory/import" class="block w-full text-center px-4 py-2 bg-inventory-50 text-inventory-700 rounded-lg hover:bg-inventory-100 transition-colors text-sm font-medium">
            📄 Import CSV
          </a>
        </div>
      </Card>
    </div>
  </div>

  <!-- Success/Error Alert -->
  <div id="alertBox" class="fixed top-20 right-4 max-w-md hidden z-50">
    <!-- Alert content will be inserted here -->
  </div>
</MainLayout>

<script>
  const API_BASE = 'https://pklproject-production.up.railway.app/api';

  // State management
  let selectedVariant = null;

  // DOM Elements
  const productSelect = document.getElementById('productSelect');
  const colorSelect = document.getElementById('colorSelect');
  const sizeSelect = document.getElementById('sizeSelect');
  const variantInfo = document.getElementById('variantInfo');
  const variantDetails = document.getElementById('variantDetails');
  const currentStockDisplay = document.getElementById('currentStock');
  const stockInputForm = document.getElementById('stockInputForm');
  const alertBox = document.getElementById('alertBox');

  // Fetch colors when product is selected
  productSelect.addEventListener('change', async () => {
    const productId = productSelect.value;
    colorSelect.innerHTML = '<option value="">Memuat...</option>';
    colorSelect.disabled = true;
    sizeSelect.disabled = true;
    variantInfo.classList.add('hidden');

    if (!productId) {
      colorSelect.innerHTML = '<option value="">Pilih Produk Terlebih Dahulu</option>';
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/inventory/colors/${productId}`);
      const result = await response.json();

      colorSelect.innerHTML = '<option value="">Pilih Warna</option>';
      if (result.success && result.data) {
        result.data.forEach((color) => {
          const option = document.createElement('option');
          option.value = color.color_id;
          option.textContent = color.color_name;
          colorSelect.appendChild(option);
        });
      }
      colorSelect.disabled = false;
    } catch (error) {
      showAlert('error', 'Gagal memuat data warna');
      colorSelect.innerHTML = '<option value="">Error</option>';
    }
  });

  // Fetch sizes when color is selected
  colorSelect.addEventListener('change', async () => {
    const productId = productSelect.value;
    const colorId = colorSelect.value;
    sizeSelect.innerHTML = '<option value="">Memuat...</option>';
    sizeSelect.disabled = true;
    variantInfo.classList.add('hidden');

    if (!colorId) {
      sizeSelect.innerHTML = '<option value="">Pilih Warna Terlebih Dahulu</option>';
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/inventory/sizes/${productId}/${colorId}`);
      const result = await response.json();

      sizeSelect.innerHTML = '<option value="">Pilih Ukuran</option>';
      if (result.success && result.data) {
        result.data.forEach((size) => {
          const option = document.createElement('option');
          option.value = size.size_id;
          option.textContent = `${size.size_name} (Stok: ${size.total_qty || 0})`;
          option.dataset.variantData = JSON.stringify(size);
          sizeSelect.appendChild(option);
        });
      }
      sizeSelect.disabled = false;
    } catch (error) {
      showAlert('error', 'Gagal memuat data ukuran');
      sizeSelect.innerHTML = '<option value="">Error</option>';
    }
  });

  // Show variant info when size is selected
  sizeSelect.addEventListener('change', () => {
    const selectedOption = sizeSelect.options[sizeSelect.selectedIndex];
    const variantData = selectedOption.dataset.variantData;

    if (variantData) {
      const data = JSON.parse(variantData);
      selectedVariant = data;

      const productName = productSelect.options[productSelect.selectedIndex].text;
      const colorName = colorSelect.options[colorSelect.selectedIndex].text;
      const sizeName = data.size_name;

      variantDetails.textContent = `${productName} - ${colorName} - ${sizeName}`;
      currentStockDisplay.textContent = data.total_qty || 0;
      variantInfo.classList.remove('hidden');
    } else {
      selectedVariant = null;
      variantInfo.classList.add('hidden');
    }
  });

  // Handle form submission
  stockInputForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(stockInputForm);
    const data = {
      product_color_size_id: selectedVariant?.variant_id,
      location_id: formData.get('location_id'),
      movement_type: 'IN',
      quantity: parseInt(formData.get('quantity')),
      reason_code: formData.get('reason_code'),
      unit_cost: formData.get('unit_cost') ? parseFloat(formData.get('unit_cost')) : null,
      notes: formData.get('notes'),
      created_by: 'current_user' // ntar login
    };

    if (!data.product_color_size_id) {
      showAlert('error', 'Silakan pilih varian produk terlebih dahulu');
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/inventory/movements`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      const result = await response.json();

      if (result.success) {
        showAlert('success', `Berhasil menambahkan ${data.quantity} unit stok!`);
        stockInputForm.reset();
        variantInfo.classList.add('hidden');
        loadRecentActivity();
      } else {
        showAlert('error', result.error?.message || 'Gagal menyimpan stok');
      }
    } catch (error) {
      showAlert('error', 'Terjadi kesalahan saat menyimpan stok');
    }
  });

  // Show alert message
  function showAlert(type, message) {
    const bgColor = type === 'success' ? 'bg-green-500' : 'bg-red-500';
    const icon = type === 'success'
      ? '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>'
      : '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';

    alertBox.innerHTML = `
      <div class="${bgColor} text-white px-4 py-3 rounded-lg shadow-lg flex items-center space-x-3">
        ${icon}
        <span class="font-medium">${message}</span>
        <button onclick="this.parentElement.parentElement.classList.add('hidden')" class="ml-auto hover:opacity-75">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    `;
    alertBox.classList.remove('hidden');

    setTimeout(() => {
      alertBox.classList.add('hidden');
    }, 5000);
  }

  // Load recent activity
  async function loadRecentActivity() {
    const activityContainer = document.getElementById('recentActivity');

    try {
      const response = await fetch(`${API_BASE}/inventory/movements?limit=5`);
      const result = await response.json();

      if (result.success && result.data && result.data.length > 0) {
        activityContainer.innerHTML = result.data.map((movement) => `
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">
                ${movement.product_name}
              </p>
              <p class="text-xs text-gray-500">
                ${movement.color_name} - ${movement.size_name}
              </p>
            </div>
            <div class="ml-2 text-right">
              <span class="inline-flex items-center px-2 py-1 text-xs font-semibold rounded-full ${
                movement.movement_type === 'IN' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'
              }">
                ${movement.movement_type === 'IN' ? '+' : '-'}${movement.quantity}
              </span>
              <p class="text-xs text-gray-500 mt-1">
                ${new Date(movement.movement_date).toLocaleDateString('id-ID')}
              </p>
            </div>
          </div>
        `).join('');
      } else {
        activityContainer.innerHTML = '<p class="text-sm text-gray-500 text-center py-4">Belum ada aktivitas</p>';
      }
    } catch (error) {
      activityContainer.innerHTML = '<p class="text-sm text-red-500 text-center py-4">Gagal memuat aktivitas</p>';
    }
  }

  // Load recent activity on page load
  loadRecentActivity();
</script>
