---
interface Props {
  activeModule?: string;
}

const { activeModule } = Astro.props;

const modules = [
  { id: 'home', name: 'Dashboard', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', href: '/', color: 'gray' },
  { id: 'sales', name: 'Penjualan', icon: 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z', href: '/sales', color: 'sales' },
  { id: 'finance', name: 'Keuangan', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', href: '/finance', color: 'finance' },
  { id: 'inventory', name: 'Persediaan', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4', href: '/inventory', color: 'inventory' },
  { id: 'crm', name: 'CRM', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', href: '/crm', color: 'crm' },
  { id: 'hr', name: 'HR', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', href: '/hr', color: 'hr' },
];

const isActive = (id: string) => activeModule === id;
---

<aside class="hidden xl:block w-64 bg-white border-r border-gray-200 flex-shrink-0 fixed top-16 left-0 h-[calc(100vh-4rem)] z-40">
  <div class="h-full px-3 py-6">
    <div class="mb-6 px-3">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Menu Utama</h2>
    </div>

    <ul class="space-y-1">
      {modules.map(module => (
        <li>
          <a
            href={module.href}
            class:list={[
              "flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors group",
              isActive(module.id)
                ? `bg-${module.color}-50 text-${module.color}-700`
                : 'text-gray-700 hover:bg-gray-100'
            ]}
          >
            <svg
              class:list={[
                "w-5 h-5 mr-3 flex-shrink-0 transition-colors",
                isActive(module.id) ? `text-${module.color}-500` : 'text-gray-400 group-hover:text-gray-500'
              ]}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={module.icon} />
            </svg>
            <span>{module.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
