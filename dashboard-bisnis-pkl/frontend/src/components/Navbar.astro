---
interface Props {
  activeModule?: string;
}

const { activeModule } = Astro.props;

const modules = [
  { id: 'home', name: 'Beranda', href: '/', module: 'dashboard' },
  { id: 'sales', name: 'Penjualan', href: '/sales', module: 'sales' },
  { id: 'finance', name: 'Keuangan', href: '/finance', module: 'finance' },
  { id: 'inventory', name: 'Persediaan', href: '/inventory', module: 'inventory' },
  { id: 'crm', name: 'CRM', href: '/crm', module: 'crm' },
  { id: 'hr', name: 'HR', href: '/hr', module: 'hr' },
];

const getColorClasses = (id: string) => {
  const colors = {
    sales: 'sales',
    finance: 'finance',
    inventory: 'inventory',
    crm: 'crm',
    hr: 'hr'
  };
  const color = colors[id as keyof typeof colors] || 'gray';

  return activeModule === id
    ? `bg-${color}-100 text-${color}-700`
    : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900';
};

const getMobileLinkColor = (id: string) => {
  const colors = {
    sales: 'sales',
    finance: 'finance',
    inventory: 'inventory',
    crm: 'crm',
    hr: 'hr'
  };
  const color = colors[id as keyof typeof colors] || 'gray';

  return activeModule === id
    ? `bg-${color}-50 text-${color}-700 font-medium`
    : 'text-gray-600 hover:bg-gray-50 hover:text-gray-900';
};
---

<nav class="bg-white shadow-sm border-b border-gray-200 fixed top-0 left-0 right-0 z-50">
  <div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-3">
          <img src="/logo.png" alt="Logo" class="w-10 h-10 rounded-lg" />
          <div>
            <span class="text-xl font-bold text-gray-900 block leading-tight">Dashboard Bisnis</span>
            <span class="text-xs text-gray-500">Nakia Suryanto's PKL Project</span>
          </div>
        </a>
      </div>

      <!-- User Menu -->
      <div class="flex items-center space-x-3">
        <div id="navUserInfo" class="hidden sm:flex items-center space-x-2 px-3 py-2 rounded-lg">
          <div class="w-8 h-8 bg-gradient-to-br from-blue-400 to-purple-500 rounded-full flex items-center justify-center">
            <span id="navUserInitial" class="text-white text-sm font-medium">?</span>
          </div>
          <span id="navUserName" class="text-sm font-medium text-gray-700">Loading...</span>
        </div>
        <button id="navLogoutBtn" class="hidden sm:flex p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors" title="Logout">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        </button>
        <button class="xl:hidden p-2 rounded-lg hover:bg-gray-100">
          <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="lg:hidden border-t border-gray-200">
    <div class="px-2 pt-2 pb-3 space-y-1 overflow-x-auto">
      <div class="flex space-x-1">
        {modules.map(mod => (
          <a
            href={mod.href}
            data-module={mod.module}
            class:list={[
              "nav-item px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors",
              activeModule === mod.id ? "bg-gray-100 text-gray-900" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900"
            ]}
          >
            {mod.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>
